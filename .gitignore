# Ignore everything by default
*

# Allow only hint/documentation files
!.gitignore
!LICENSE
!README.md
!project.md
!QUICK_START.md
!SETUP_AND_RUN.md
!CLAUDE.md
!Qwen2.5-VL-7B-Instruct.txt

# Allow database schema (DDL only, no data)
!database/
database/*
!database/schema.sql

# Allow env example templates
!backend/
backend/*
!backend/.env.example

!frontend/
frontend/*
!frontend/.env.local.example

# Allow screenshots placeholder
!screenshots/
screenshots/*
!screenshots/README.txt
