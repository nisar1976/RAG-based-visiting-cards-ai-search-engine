# PostgreSQL Database Connection
# Format: postgresql+asyncpg://username:password@host:port/database
# Replace with your actual database credentials
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/visitingcards

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
# Required for Vision API (OCR) and Embeddings
OPENAI_API_KEY=sk-proj-YOUR_API_KEY_HERE

# Optional: Assets directory path
# Default: ../assets (relative to backend directory)
ASSETS_DIR=../assets
